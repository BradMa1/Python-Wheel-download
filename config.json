{
  // =============================================
  //  Python Wheel 包下载工具 - 配置文件
  // =============================================



  // 【目标 Python 版本】填写目标机器的 Python 版本号
  // 查看方法：在目标机器上运行 python3 --version

  "target_python": "3.10",



  // 【目标平台/系统】填写目标机器的操作系统和架构
  // 示例：
  //   "manylinux2014_x86_64"  → Linux x86_64 (最常见，腾讯云/阿里云等)
  //   "manylinux2014_aarch64" → Linux ARM64 (树莓派、部分云服务器)
  //   "macosx_11_0_x86_64"    → macOS Intel
  //   "macosx_11_0_arm64"     → macOS M1/M2/M3
  //   "win_amd64"             → Windows x86_64
  "target_platform": "manylinux2014_x86_64",



  // 【并行下载线程数】
  // 同时下载多少个包，数字越大越快，但可能占带宽
  // 一般 4~16 之间，机器配置差就改小点
  "max_workers": 8,



  // 【是否跳过已下载的包】
  // true  → 目录下已有的包跳过，节省时间（推荐）
  // false → 每次重新下载所有包
  "skip_existing": true,



  // 【PyPI 镜像源】 按顺序尝试，成功即止
  // 如目标机器在国内，建议保持前三个国内镜像 如目标机器在国外，可只保留最后一个官方源
  // 示例：
  //   ["https://pypi.org/simple"]                    → 只用官方源（国外机器）
  //   ["https://pypi.tuna.tsinghua.edu.cn/simple"]  → 只用清华源

  "mirrors": [
    "https://pypi.tuna.tsinghua.edu.cn/simple",
    "https://mirrors.aliyun.com/pypi/simple",
    "https://mirrors.cloud.tencent.com/pypi/simple",
    "https://pypi.org/simple"
  ]
}
